{
  "name": "whoisleuth",
  "version": "1.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Domain intelligence and brand-protection toolkit built on WHOIS/RDAP - lookups, bulk scans, availability/opportunity scoring, typosquat detection, and watchlist monitoring.",
  "files": [
    "bin/**/*.mts",
    "cli/**/*.mts",
    "lib/**/*.mts",
    "docs/cli.md",
    "LICENSE",
    "NOTICE",
    "TRADEMARKS.md"
  ],
  "bin": {
    "whoisleuth": "bin/whoisleuth.mts"
  },
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "start": "npm run build && node server.mts",
    "test": "node --test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p frontend/analysis-tsconfig.json && tsc --noEmit -p e2e/tsconfig.json",
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "check": "npm run check --workspace=frontend",
    "test:e2e": "playwright test",
    "test:e2e:built": "WHOISLEUTH_E2E_USE_BUILD=1 playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "schema:inventory": "node tools/schema-inventory.mts",
    "deployment:self-check": "node tools/deployment-self-check.mts",
    "registry:drift": "node tools/registry-drift-audit.mts",
    "benchmark:workflow": "node tools/specialist-workflow-benchmark.mts",
    "platform:local-data": "node tools/local-data-platform-evaluation.mts",
    "security:codeql": "node tools/local-codeql.mts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@netlify/blobs": "10.1.0",
    "express": "^5.2.1",
    "tldts": "^7.4.8",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
