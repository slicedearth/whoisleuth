{
  "name": "whoisleuth",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Domain intelligence and brand-protection toolkit built on WHOIS/RDAP - lookups, bulk scans, availability/opportunity scoring, typosquat detection, and watchlist monitoring.",
  "main": "server.js",
  "workspaces": ["frontend"],
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p public/tsconfig.json",
    "dev:svelte": "npm run dev --workspace=frontend",
    "build:svelte": "npm run build --workspace=frontend",
    "check:svelte": "npm run check --workspace=frontend",
    "start:svelte": "npm run build:svelte && node server.js"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "express": "^4.19.2",
    "tldts": "^7.4.8",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
