{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "checkJs": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": false,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "lib/**/*.js",
    "lib/**/*.mjs",
    "lib/**/*.ts",
    "lib/**/*.mts",
    "lib/**/*.cts",
    "server.js",
    "server.ts",
    "netlify/**/*.js",
    "netlify/**/*.ts",
    "netlify/**/*.mts",
    "netlify/**/*.cts",
    "cli/**/*.js",
    "cli/**/*.ts",
    "cli/**/*.mts",
    "cli/**/*.cts",
    "bin/**/*.js",
    "bin/**/*.ts",
    "bin/**/*.mts",
    "bin/**/*.cts"
  ]
}
